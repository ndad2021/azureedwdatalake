{
	"name": "CopyPipeline_ufh",
	"properties": {
		"activities": [
			{
				"name": "Copy_ufh",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [
					{
						"name": "Source",
						"value": "photos//us-500.csv"
					},
					{
						"name": "Destination",
						"value": "photos//"
					}
				],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobStorageReadSettings",
							"recursive": false,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings",
							"skipLineCount": 0
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "setOfObjects"
						}
					},
					"enableStaging": false,
					"enableSkipIncompatibleRow": true,
					"validateDataConsistency": true,
					"logSettings": {
						"enableCopyActivityLog": true,
						"copyActivityLogSettings": {
							"logLevel": "Warning",
							"enableReliableLogging": false
						},
						"logLocationSettings": {
							"linkedServiceName": {
								"referenceName": "AzureBlobStorage1",
								"type": "LinkedServiceReference"
							},
							"path": "photos"
						}
					},
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "first_name",
									"type": "String"
								},
								"sink": {
									"path": "$['first_name']"
								}
							},
							{
								"source": {
									"name": "last_name",
									"type": "String"
								},
								"sink": {
									"path": "$['last_name']"
								}
							},
							{
								"source": {
									"name": "company_name",
									"type": "String"
								},
								"sink": {
									"path": "$['company_name']"
								}
							},
							{
								"source": {
									"name": "address",
									"type": "String"
								},
								"sink": {
									"path": "$['address']"
								}
							},
							{
								"source": {
									"name": "city",
									"type": "String"
								},
								"sink": {
									"path": "$['city']"
								}
							},
							{
								"source": {
									"name": "county",
									"type": "String"
								},
								"sink": {
									"path": "$['county']"
								}
							},
							{
								"source": {
									"name": "state",
									"type": "String"
								},
								"sink": {
									"path": "$['state']"
								}
							},
							{
								"source": {
									"name": "zip",
									"type": "String"
								},
								"sink": {
									"path": "$['zip']"
								}
							},
							{
								"source": {
									"name": "phone1",
									"type": "String"
								},
								"sink": {
									"path": "$['phone1']"
								}
							},
							{
								"source": {
									"name": "phone2",
									"type": "String"
								},
								"sink": {
									"path": "$['phone2']"
								}
							},
							{
								"source": {
									"name": "email",
									"type": "String"
								},
								"sink": {
									"path": "$['email']"
								}
							},
							{
								"source": {
									"name": "web",
									"type": "String"
								},
								"sink": {
									"path": "$['web']"
								}
							}
						]
					}
				},
				"inputs": [
					{
						"referenceName": "SourceDataset_ufh",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "DestinationDataset_ufh",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}